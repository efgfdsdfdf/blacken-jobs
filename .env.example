# =============================================================================
# BLACK AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Local Docker: postgresql://postgres:postgres_dev_password@localhost:5432/blackai
# Supabase:     Get from Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:postgres_dev_password@localhost:5432/blackai"
DIRECT_URL="postgresql://postgres:postgres_dev_password@localhost:5432/blackai"

# -----------------------------------------------------------------------------
# Supabase Auth
# -----------------------------------------------------------------------------
# Get from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-jwt-secret"

# -----------------------------------------------------------------------------
# Redis (Rate Limiting)
# -----------------------------------------------------------------------------
# Local Docker: redis://localhost:6379
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
API_PORT=4000
API_URL="http://localhost:4000"
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# OpenAI (Phase 2+)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY="sk-..."

# -----------------------------------------------------------------------------
# Stripe (Phase 5+)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
